{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/.vscode/tauri-v2.schema.json",
  "productName": "Tumbler",
  "version": "2.10.2",
  "identifier": "com.brocla.tumbler",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cargo build --release --manifest-path src-tauri/Cargo.toml -p tumbler-thumbnailer && cmd /c copy /y src-tauri\\target\\release\\tumbler_thumbnailer.dll src-tauri\\resources\\tumbler-thumbnailer.dll && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tumbler",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "resources": [
      "resources/pdfium.dll",
      "resources/tumbler-thumbnailer.dll",
      "resources/qpdf.dll",
      "resources/msvcp140.dll",
      "resources/vcruntime140.dll",
      "resources/vcruntime140_1.dll"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "pdf"
        ],
        "name": "PDF Document",
        "description": "PDF Document",
        "mimeType": "application/pdf",
        "role": "Viewer"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "wix": {
        "fragmentPaths": [
          "wix/file-associations.wxs"
        ],
        "componentGroupRefs": [
          "TumblerFileAssociationGroup"
        ]
      }
    }
  },
  "plugins": {}
}
