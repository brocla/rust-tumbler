<?xml version="1.0" encoding="utf-8"?>
<!--
  Registers Tumbler under HKLM\Software\RegisteredApplications so it shows up
  as a selectable default app for .pdf in Windows Settings > Default Apps.
  Tauri's generated main.wxs already creates the "Tumbler.pdf" ProgId and its
  .pdf Extension association under HKLM\Software\Classes; this fragment only
  adds the Capabilities/RegisteredApplications entries Windows needs to list
  that ProgId in the default-apps picker (see tauri-apps/tauri#9803).

  It also registers the IThumbnailProvider COM handler machine-wide (HKLM) so
  Explorer shows first-page PDF previews for *every* user account, not just the
  one that runs Tumbler. Because this is a per-machine (perMachine) MSI that
  installs to Program Files, the DLL is readable by all users and HKLM is the
  correct scope. DisableProcessIsolation=1 makes the handler run in-process
  (Explorer's sandboxed surrogate can't LoadLibrary our pdfium.dll).
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <DirectoryRef Id="TARGETDIR">
      <Component Id="TumblerFileAssociationCapabilities" Guid="72545816-3206-41B7-B941-299AF65B9881" Win64="yes">
        <RegistryValue Root="HKLM" Key="Software\Tumbler\Capabilities" Name="ApplicationName" Value="Tumbler" Type="string" />
        <RegistryValue Root="HKLM" Key="Software\Tumbler\Capabilities" Name="ApplicationDescription" Value="A personal PDF viewer" Type="string" />
        <RegistryValue Root="HKLM" Key="Software\Tumbler\Capabilities\FileAssociations" Name=".pdf" Value="Tumbler.pdf" Type="string" KeyPath="yes" />
        <RegistryValue Root="HKLM" Key="Software\RegisteredApplications" Name="Tumbler" Value="Software\Tumbler\Capabilities" Type="string" />
      </Component>

      <Component Id="TumblerThumbnailHandler" Guid="ACC5BA02-19A3-46FC-9A04-CEF8BC776A07" Win64="yes">
        <!-- The COM class for our IThumbnailProvider. -->
        <RegistryValue Root="HKLM" Key="Software\Classes\CLSID\{0E3D8445-C38C-45EE-9FD3-A5EA0B089DEE}" Value="Tumbler PDF Thumbnail Provider" Type="string" KeyPath="yes" />
        <RegistryValue Root="HKLM" Key="Software\Classes\CLSID\{0E3D8445-C38C-45EE-9FD3-A5EA0B089DEE}" Name="DisableProcessIsolation" Value="1" Type="integer" />
        <RegistryValue Root="HKLM" Key="Software\Classes\CLSID\{0E3D8445-C38C-45EE-9FD3-A5EA0B089DEE}\InprocServer32" Value="[INSTALLDIR]resources\tumbler-thumbnailer.dll" Type="string" />
        <RegistryValue Root="HKLM" Key="Software\Classes\CLSID\{0E3D8445-C38C-45EE-9FD3-A5EA0B089DEE}\InprocServer32" Name="ThreadingModel" Value="Apartment" Type="string" />
        <!-- Point the .pdf thumbnail-handler shell-extension slot at our CLSID. -->
        <RegistryValue Root="HKLM" Key="Software\Classes\.pdf\ShellEx\{e357fccd-a995-4576-b01f-234630154e96}" Value="{0E3D8445-C38C-45EE-9FD3-A5EA0B089DEE}" Type="string" />
      </Component>
    </DirectoryRef>

    <ComponentGroup Id="TumblerFileAssociationGroup">
      <ComponentRef Id="TumblerFileAssociationCapabilities" />
      <ComponentRef Id="TumblerThumbnailHandler" />
    </ComponentGroup>
  </Fragment>
</Wix>
